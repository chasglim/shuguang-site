---
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-inner">
		<p>&copy; {today.getFullYear()} Shuguang Zhang. Personal research notes and engineering writing.</p>
		<p>The views expressed here are my own and do not represent my employer.</p>
		<div class="footer-links">
			<a href="/rss.xml">RSS</a>
			<a href="https://github.com/chasglim/shuguang-site" target="_blank" rel="noreferrer">GitHub</a>
		</div>
	</div>
</footer>
<style>
	.site-footer {
		border-top: 1px solid var(--line);
		background: #f0ece2;
		color: var(--muted);
	}
	.footer-inner {
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 2.4rem 0 4rem;
		font-size: 0.92rem;
	}
	.footer-inner p {
		max-width: 760px;
		margin: 0.3rem 0;
	}
	.footer-links {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}
	.footer-links a {
		color: var(--ink);
	}
</style>
