---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import Page from '../../layouts/Page.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Page
	title="Writing"
	description="Archive of essays on AI security, cryptography, privacy computing, secure RAG, and agent governance."
>
	<section class="intro">
		<p class="eyebrow">Writing Archive</p>
		<h1>Essays and technical arguments</h1>
		<p>正式文章会逐步沉淀到这里。主导航使用 Writing，旧的 /blog 路径保留为兼容入口。</p>
	</section>

	<section class="section" aria-labelledby="archive-title">
		<div class="section-header">
			<div>
				<p class="eyebrow">Archive</p>
				<h2 id="archive-title">All writing</h2>
			</div>
		</div>
		<div class="writing-list">
			{
				posts.map((post) => (
					<article class="writing-item">
						<div class="writing-date">
							<FormattedDate date={post.data.pubDate} />
						</div>
						<div>
							<h2>{post.data.title}</h2>
							<p>{post.data.description}</p>
						</div>
						<a href={`/blog/${post.id}/`}>Read</a>
					</article>
				))
			}
		</div>
	</section>
</Page>
