---
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Page from '../layouts/Page.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Page
	title="Writing"
	description="Long-form essays on AI security, cryptography, privacy computing, secure RAG, and agent governance."
>
	<section class="intro">
		<p class="eyebrow">Writing</p>
		<h1>Essays on secure AI systems</h1>
		<p>
			这里放正式长文：不是泛泛讲大模型，而是站在金融、密码、安全和工程落地的交叉点上讨论问题。
		</p>
		<div class="tag-row">
			<span class="tag">AI Security</span>
			<span class="tag">Cryptography</span>
			<span class="tag">Privacy Computing</span>
			<span class="tag">Agent Governance</span>
			<span class="tag">Secure RAG</span>
		</div>
	</section>

	<section class="section" aria-labelledby="essay-title">
		<div class="section-header">
			<div>
				<p class="eyebrow">Latest Writing</p>
				<h2 id="essay-title">Current drafts</h2>
			</div>
		</div>
		<div class="writing-list">
			{
				posts.map((post) => (
					<article class="writing-item">
						<div class="writing-date">
							<FormattedDate date={post.data.pubDate} />
						</div>
						<div>
							<h2>{post.data.title}</h2>
							<p>{post.data.description}</p>
						</div>
						<a href={`/blog/${post.id}/`}>Read</a>
					</article>
				))
			}
		</div>
	</section>
</Page>
