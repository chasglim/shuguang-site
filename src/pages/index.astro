---
import Page from '../layouts/Page.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<Page title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="profile">
		<p class="eyebrow">Personal Introduction</p>
		<h1>张曙光 / Shuguang Zhang</h1>
		<p class="lede">金融 AI 安全 / 隐私计算 / 后量子密码 / Agent Memory Governance</p>
		<div class="profile-body">
			<p>
				I build secure AI systems at the intersection of cryptography, financial infrastructure, and agent governance.
			</p>
			<p>
				我关注金融基础设施中的 AI 安全、密码工程、隐私计算与智能体治理，尤其是能够落到系统、工具和可审计流程里的研究问题。
			</p>
			<p class="disclaimer">本文和本站内容仅代表个人研究与技术观点，不代表所在单位立场。</p>
		</div>
	</section>
</Page>
